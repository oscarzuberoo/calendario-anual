<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>To Do Visual</title>
  <style>
    :root{
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #2b2b2b;
      --muted: #7a7a7a;
      --border: #e3e7ee;
      --primary: #2196f3;
      --ok: #4caf50;
      --danger: #ff5252;
      --shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    * { box-sizing: border-box; }

    body{
      margin:0;
      font-family:'Segoe UI', Roboto, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      padding: 24px;
    }

    .todo-app{
      max-width: 720px;
      margin: 0 auto;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .todo-header{
      padding: 20px 22px;
      background: linear-gradient(135deg, #2196f3, #64b5f6);
      color: white;
    }

    .todo-header h1{
      margin:0;
      font-size: 1.4rem;
    }

    .todo-header p{
      margin:6px 0 0;
      opacity:0.95;
      font-size: 0.95rem;
    }

    .todo-input-wrap{
      display:flex;
      gap:10px;
      padding: 18px 22px;
      border-bottom: 1px solid var(--border);
      background: #fbfcfe;
    }

    .todo-input{
      flex:1;
      border:1px solid var(--border);
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 0.98rem;
      outline:none;
    }

    .todo-input:focus{
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(33,150,243,0.12);
    }

    .btn{
      border:none;
      border-radius: 12px;
      padding: 12px 16px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-add{
      background: var(--primary);
      color:white;
    }

    .todo-toolbar{
      display:flex;
      justify-content: space-between;
      align-items:center;
      padding: 14px 22px;
      border-bottom: 1px solid var(--border);
      gap: 12px;
      flex-wrap: wrap;
    }

    .filters{
      display:flex;
      gap:8px;
      flex-wrap: wrap;
    }

    .filter-btn{
      background:#eef4fb;
      color:#336;
      border:none;
      border-radius: 999px;
      padding: 8px 12px;
      cursor:pointer;
      font-weight:600;
    }

    .filter-btn.active{
      background: var(--primary);
      color:white;
    }

    .summary{
      font-size: 0.92rem;
      color: var(--muted);
      font-weight: 600;
    }

    .todo-list{
      list-style:none;
      margin:0;
      padding: 14px;
      display:flex;
      flex-direction:column;
      gap:10px;
      min-height: 140px;
    }

    .todo-item{
      display:flex;
      align-items:center;
      gap:12px;
      background:white;
      border:1px solid var(--border);
      border-radius: 14px;
      padding: 14px;
      transition: 0.2s ease;
    }

    .todo-item:hover{
      transform: translateY(-1px);
      box-shadow: 0 6px 18px rgba(0,0,0,0.05);
    }

    .todo-check{
      width:22px;
      height:22px;
      cursor:pointer;
      accent-color: var(--ok);
      flex-shrink: 0;
    }

    .todo-text{
      flex:1;
      font-size: 0.98rem;
      line-height: 1.35;
      word-break: break-word;
    }

    .todo-item.done .todo-text{
      text-decoration: line-through;
      color: #9aa3af;
    }

    .todo-actions{
      display:flex;
      gap:8px;
      flex-shrink: 0;
    }

    .icon-btn{
      border:none;
      cursor:pointer;
      border-radius: 10px;
      padding: 8px 10px;
      font-weight:700;
    }

    .btn-delete{
      background: #ffe9e9;
      color: #c62828;
    }

    .btn-clear{
      background: #fff2f2;
      color: var(--danger);
    }

    .empty{
      text-align:center;
      color: var(--muted);
      padding: 30px 12px;
      font-size: 0.98rem;
    }

    @media (max-width: 640px){
      .todo-input-wrap{
        flex-direction:column;
      }

      .btn-add{
        width:100%;
      }

      .todo-toolbar{
        align-items:flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="todo-app">
    <div class="todo-header">
      <h1>Mi To Do</h1>
      <p>Lista sencilla, visual y rápida</p>
    </div>

    <div class="todo-input-wrap">
      <input
        id="todoInput"
        class="todo-input"
        type="text"
        placeholder="Escribe una tarea..."
        maxlength="140"
      />
      <button class="btn btn-add" id="addBtn">Añadir</button>
    </div>

    <div class="todo-toolbar">
      <div class="filters">
        <button class="filter-btn active" data-filter="all">Todas</button>
        <button class="filter-btn" data-filter="pending">Pendientes</button>
        <button class="filter-btn" data-filter="done">Hechas</button>
      </div>

      <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <span class="summary" id="summaryText">0 pendientes</span>
        <button class="icon-btn btn-clear" id="clearDoneBtn">Borrar hechas</button>
      </div>
    </div>

    <ul class="todo-list" id="todoList"></ul>
  </div>

  <script>
    const STORAGE_KEY = 'todo_visual_items_v1';

    let todos = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    let currentFilter = 'all';

    const todoInput = document.getElementById('todoInput');
    const addBtn = document.getElementById('addBtn');
    const todoList = document.getElementById('todoList');
    const summaryText = document.getElementById('summaryText');
    const clearDoneBtn = document.getElementById('clearDoneBtn');
    const filterButtons = document.querySelectorAll('.filter-btn');

    function saveTodos() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
    }

    function addTodo() {
      const text = todoInput.value.trim();
      if (!text) return;

      todos.unshift({
        id: Date.now(),
        text,
        done: false
      });

      todoInput.value = '';
      saveTodos();
      renderTodos();
    }

    function toggleTodo(id) {
      todos = todos.map(todo =>
        todo.id === id ? { ...todo, done: !todo.done } : todo
      );
      saveTodos();
      renderTodos();
    }

    function deleteTodo(id) {
      todos = todos.filter(todo => todo.id !== id);
      saveTodos();
      renderTodos();
    }

    function clearDone() {
      todos = todos.filter(todo => !todo.done);
      saveTodos();
      renderTodos();
    }

    function getFilteredTodos() {
      if (currentFilter === 'pending') return todos.filter(t => !t.done);
      if (currentFilter === 'done') return todos.filter(t => t.done);
      return todos;
    }

    function updateSummary() {
      const pending = todos.filter(t => !t.done).length;
      summaryText.textContent = `${pending} pendiente${pending === 1 ? '' : 's'}`;
    }

    function renderTodos() {
      const filtered = getFilteredTodos();
      todoList.innerHTML = '';

      if (!filtered.length) {
        todoList.innerHTML = `<div class="empty">No hay tareas en esta vista</div>`;
        updateSummary();
        return;
      }

      filtered.forEach(todo => {
        const li = document.createElement('li');
        li.className = `todo-item ${todo.done ? 'done' : ''}`;

        li.innerHTML = `
          <input class="todo-check" type="checkbox" ${todo.done ? 'checked' : ''}>
          <div class="todo-text">${escapeHtml(todo.text)}</div>
          <div class="todo-actions">
            <button class="icon-btn btn-delete">Eliminar</button>
          </div>
        `;

        li.querySelector('.todo-check').addEventListener('change', () => toggleTodo(todo.id));
        li.querySelector('.btn-delete').addEventListener('click', () => deleteTodo(todo.id));

        todoList.appendChild(li);
      });

      updateSummary();
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    addBtn.addEventListener('click', addTodo);

    todoInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') addTodo();
    });

    clearDoneBtn.addEventListener('click', clearDone);

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        currentFilter = btn.dataset.filter;
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderTodos();
      });
    });

    renderTodos();
  </script>
</body>
</html>
